{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/skill.schema.json",
  "title": "Skills Package Manifest",
  "type": "object",
  "required": ["schema_version", "name", "version", "description", "entrypoint"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "name": {
      "type": "string",
      "maxLength": 64,
      "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$"
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1024
    },
    "entrypoint": {
      "type": "string",
      "const": "SKILL.md"
    },
    "license": {
      "type": "string"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "email": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    },
    "keywords": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "repository": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["git"] },
        "url": { "type": "string" },
        "path": { "type": "string" },
        "revision": { "type": "string" }
      }
    },
    "source": {
      "type": "object",
      "required": ["type", "url"],
      "additionalProperties": false,
      "properties": {
        "type": { "type": "string", "enum": ["git", "registry", "archive", "path"] },
        "url": { "type": "string" },
        "path": { "type": "string" },
        "revision": { "type": "string" }
      }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "filesystem": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": { "type": "boolean" },
            "write": { "type": "boolean" }
          }
        },
        "network": { "type": "boolean" },
        "commands": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "execute": { "type": "boolean" },
            "allowed": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            }
          }
        },
        "secrets": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "reads_secrets": { "type": "boolean" },
            "writes_secrets": { "type": "boolean" }
          }
        }
      }
    },
    "commands": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["description", "runners"],
        "additionalProperties": false,
        "properties": {
          "description": { "type": "string" },
          "runners": {
            "type": "object",
            "minProperties": 1,
            "propertyNames": { "pattern": "^[a-z0-9](?:[a-z0-9-]*[a-z0-9])?$" },
            "additionalProperties": {
              "type": "object",
              "required": ["command"],
              "additionalProperties": false,
              "properties": {
                "command": { "type": "string" },
                "requires": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "language_bindings": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "package": { "type": "string" },
          "module": { "type": "string" },
          "min_runtime": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "version"],
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        },
        "system": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "update": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["semver", "none"] },
        "channel": { "type": "string" },
        "allow_major": { "type": "boolean" },
        "auto_update": { "type": "boolean" }
      }
    }
  }
}
